# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code — personal overrides only; team settings are committed
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase CLI local state (linked-project ref, temp pooler URL, etc.)
supabase/.temp/

# worker build output
dist-worker/

# pm2 logs
/logs/

# chrome extension build + deps
/extension/dist
/extension/node_modules
