{
  "manifest_version": 3,
  "name": "Tiberius Reply",
  "version": "0.1.0",
  "description": "Draft Gmail replies with a Tiberius agent.",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Tiberius Reply — open options"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://asktiberius.de/*",
    "https://tiberius-nu.vercel.app/*",
    "http://localhost:3007/*"
  ],
  "permissions": ["storage"]
}
